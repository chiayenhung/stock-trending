{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/universe/1.0.0",
  "title": "Versioned stock universe",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "universe_id", "universe_version", "reviewed_at", "review_frequency_days", "required_buckets", "coverage", "candidate_selection", "instruments"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "universe_id": {"type": "string", "minLength": 1},
    "universe_version": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date"},
    "review_frequency_days": {"type": "integer", "minimum": 1},
    "required_buckets": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {"enum": ["semiconductor", "memory_storage", "power_infrastructure", "software"]}
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_valid_per_bucket", "minimum_valid_total"],
      "properties": {
        "minimum_valid_per_bucket": {"type": "integer", "minimum": 1},
        "minimum_valid_total": {"type": "integer", "minimum": 1}
      }
    },
    "candidate_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_per_bucket", "maximum_total", "ranking"],
      "properties": {
        "maximum_per_bucket": {"type": "integer", "minimum": 1},
        "maximum_total": {"type": "integer", "minimum": 1},
        "ranking": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "direction"],
            "properties": {
              "field": {"enum": ["momentum_20d_pct", "volume_ratio", "average_volume_20d", "symbol"]},
              "direction": {"enum": ["ascending", "descending"]}
            }
          }
        }
      }
    },
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["instrument_id", "symbol", "venue", "asset_type", "bucket", "classification_source", "effective_from", "effective_to", "active"],
        "properties": {
          "instrument_id": {"type": "string", "minLength": 1},
          "symbol": {"type": "string", "pattern": "^[A-Z0-9.-]{1,16}$"},
          "venue": {"type": "string", "minLength": 4},
          "asset_type": {"enum": ["common_stock", "adr"]},
          "bucket": {"enum": ["semiconductor", "memory_storage", "power_infrastructure", "software"]},
          "classification_source": {"type": "string", "minLength": 1},
          "effective_from": {"type": "string", "format": "date"},
          "effective_to": {"type": ["string", "null"], "format": "date"},
          "active": {"type": "boolean"}
        }
      }
    }
  }
}
