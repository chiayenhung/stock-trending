{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/analyst_output/2.0.0",
  "title": "Analyst output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "analyst_output_id",
    "instrument_id",
    "symbol",
    "score",
    "assessment",
    "confidence_bucket",
    "thesis",
    "claims",
    "horizon_sessions",
    "horizon_outlooks",
    "monitoring_triggers",
    "limitations",
    "producer"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "analyst_output_id": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string"},
    "symbol": {"type": "string"},
    "score": {"type": "number", "minimum": 1, "maximum": 10},
    "assessment": {
      "enum": ["no_action", "watch", "positive_trend", "negative_trend"]
    },
    "confidence_bucket": {"enum": ["low", "medium", "high"]},
    "thesis": {"type": "string"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "claim_type", "text", "supporting_fact_ids", "limitations"],
        "properties": {
          "claim_id": {"type": "string"},
          "claim_type": {"type": "string"},
          "text": {"type": "string"},
          "supporting_fact_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "uniqueItems": true
          },
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      },
      "minItems": 1
    },
    "horizon_sessions": {"type": "integer", "minimum": 1, "maximum": 30},
    "horizon_outlooks": {"$ref": "#/$defs/horizon_outlooks"},
    "monitoring_triggers": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "uniqueItems": true
    },
    "limitations": {"type": "array", "items": {"type": "string"}},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "model", "prompt_version"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "prompt_version": {"type": "string"}
      }
    }
  },
  "$defs": {
    "horizon_outlooks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "horizon_key",
          "horizon_sessions",
          "direction",
          "estimated_probability_pct",
          "probability_basis",
          "supporting_claim_ids",
          "limitations"
        ],
        "properties": {
          "horizon_key": {
            "enum": ["short_5d", "medium_1m", "cycle_3m"]
          },
          "horizon_sessions": {"enum": [5, 21, 63]},
          "direction": {"enum": ["up", "down", "uncertain"]},
          "estimated_probability_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "probability_basis": {"const": "model_estimate_uncalibrated"},
          "supporting_claim_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "uniqueItems": true
          },
          "limitations": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    }
  }
}
