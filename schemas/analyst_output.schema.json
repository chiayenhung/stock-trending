{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/analyst_output/1.0.0",
  "title": "Analyst output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "analyst_output_id",
    "instrument_id",
    "symbol",
    "score",
    "assessment",
    "confidence_bucket",
    "thesis",
    "claims",
    "horizon_sessions",
    "monitoring_triggers",
    "limitations",
    "producer"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "analyst_output_id": {"type": "string", "minLength": 1},
    "instrument_id": {"type": "string"},
    "symbol": {"type": "string"},
    "score": {"type": "number", "minimum": 1, "maximum": 10},
    "assessment": {
      "enum": ["no_action", "watch", "positive_trend", "negative_trend"]
    },
    "confidence_bucket": {"enum": ["low", "medium", "high"]},
    "thesis": {"type": "string"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "claim_type", "text", "supporting_fact_ids", "limitations"],
        "properties": {
          "claim_id": {"type": "string"},
          "claim_type": {"type": "string"},
          "text": {"type": "string"},
          "supporting_fact_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "uniqueItems": true
          },
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      },
      "minItems": 1
    },
    "horizon_sessions": {"type": "integer", "minimum": 1, "maximum": 30},
    "monitoring_triggers": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "uniqueItems": true
    },
    "limitations": {"type": "array", "items": {"type": "string"}},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "model", "prompt_version"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "prompt_version": {"type": "string"}
      }
    }
  }
}
