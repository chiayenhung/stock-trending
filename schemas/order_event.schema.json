{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/order_event/1.0.0",
  "title": "Order event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "client_order_id",
    "intent_id",
    "order_leg",
    "order_revision",
    "from_state",
    "to_state",
    "occurred_at",
    "broker_order_id",
    "filled_quantity",
    "average_fill_price",
    "reason"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "event_id": {"type": "string"},
    "client_order_id": {"type": "string"},
    "intent_id": {"type": "string"},
    "order_leg": {"enum": ["entry", "stop", "target", "exit", "replacement"]},
    "order_revision": {"type": "integer", "minimum": 1},
    "from_state": {"type": ["string", "null"]},
    "to_state": {"type": "string"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "broker_order_id": {"type": ["string", "null"]},
    "filled_quantity": {"type": "integer", "minimum": 0},
    "average_fill_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "reason": {"type": ["string", "null"]}
  }
}
