{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/execution_intent/1.0.0",
  "title": "Execution intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intent_id",
    "intent_revision",
    "signal_id",
    "signal_revision",
    "environment",
    "symbol",
    "venue",
    "side",
    "quantity",
    "order_type",
    "limit_price",
    "stop_price",
    "target_price",
    "risk_policy_version",
    "approval_required",
    "expires_at",
    "quote_fact_id"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "intent_id": {"type": "string"},
    "intent_revision": {"type": "integer", "minimum": 1},
    "signal_id": {"type": "string"},
    "signal_revision": {"type": "integer", "minimum": 1},
    "environment": {"enum": ["paper", "live"]},
    "symbol": {"type": "string"},
    "venue": {"type": "string"},
    "side": {"enum": ["buy", "sell"]},
    "quantity": {"type": "integer", "minimum": 1},
    "order_type": {"enum": ["limit"]},
    "limit_price": {"type": "number", "exclusiveMinimum": 0},
    "stop_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "target_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "risk_policy_version": {"type": "string"},
    "approval_required": {"type": "boolean"},
    "expires_at": {"type": "string", "format": "date-time"},
    "quote_fact_id": {"type": "string"}
  }
}
