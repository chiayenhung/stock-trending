{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/run_manifest/1.0.0",
  "title": "Run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "logical_key",
    "run_revision",
    "state",
    "identity",
    "versions",
    "artifact_hashes",
    "degraded_reasons",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string"},
    "logical_key": {"type": "string"},
    "run_revision": {"type": "integer", "minimum": 1},
    "state": {
      "enum": [
        "created",
        "ingesting",
        "normalized",
        "screened",
        "analyzed",
        "validated",
        "rendered",
        "emails_generated",
        "finalized",
        "committed",
        "failed"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_version",
        "strategy_id",
        "strategy_version",
        "venue",
        "exchange_session_date",
        "analysis_window"
      ],
      "properties": {
        "workflow_version": {"type": "string"},
        "strategy_id": {"type": "string"},
        "strategy_version": {"type": "string"},
        "venue": {"type": "string"},
        "exchange_session_date": {"type": "string", "format": "date"},
        "analysis_window": {"type": "string"}
      }
    },
    "versions": {"type": "object"},
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    },
    "degraded_reasons": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
