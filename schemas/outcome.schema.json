{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/outcome/2.0.0",
  "title": "Research signal outcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcome_id",
    "research_signal_id",
    "assessment",
    "horizon_sessions",
    "baseline_price",
    "observation_price",
    "observed_return_pct",
    "benchmark_return_pct",
    "excess_return_pct",
    "direction_correct",
    "observed_at",
    "missing_reason"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "outcome_id": {"type": "string"},
    "research_signal_id": {"type": "string"},
    "assessment": {
      "enum": ["no_action", "watch", "positive_trend", "negative_trend"]
    },
    "horizon_sessions": {"type": "integer", "minimum": 1},
    "baseline_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "observation_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "observed_return_pct": {"type": ["number", "null"]},
    "benchmark_return_pct": {"type": ["number", "null"]},
    "excess_return_pct": {"type": ["number", "null"]},
    "direction_correct": {"type": ["boolean", "null"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "missing_reason": {"type": ["string", "null"]}
  }
}
