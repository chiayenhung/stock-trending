{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stocktrend.local/schemas/research_signal/1.0.0",
  "title": "Research signal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "research_signal_id",
    "revision",
    "strategy_id",
    "strategy_version",
    "assessment",
    "instrument_id",
    "symbol",
    "venue",
    "assessed_at",
    "horizon_sessions",
    "thesis",
    "monitoring_triggers",
    "evidence_claim_ids",
    "confidence_bucket",
    "known_gaps",
    "research_only",
    "validation_status",
    "validation_reason_codes",
    "producer"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "research_signal_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 1},
    "strategy_id": {"type": "string"},
    "strategy_version": {"type": "string"},
    "assessment": {
      "enum": ["no_action", "watch", "positive_trend", "negative_trend"]
    },
    "instrument_id": {"type": "string"},
    "symbol": {"type": "string"},
    "venue": {"type": "string"},
    "assessed_at": {"type": "string", "format": "date-time"},
    "horizon_sessions": {"type": "integer", "minimum": 1, "maximum": 30},
    "thesis": {"type": "string", "minLength": 1},
    "monitoring_triggers": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence_claim_ids": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "uniqueItems": true
    },
    "confidence_bucket": {"enum": ["low", "medium", "high"]},
    "known_gaps": {"type": "array", "items": {"type": "string"}},
    "research_only": {"const": true},
    "validation_status": {
      "enum": ["pending", "pass", "reject", "indeterminate", "unavailable"]
    },
    "validation_reason_codes": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor", "model", "prompt_version", "analyst_output_ids"],
      "properties": {
        "vendor": {"type": "string"},
        "model": {"type": "string"},
        "prompt_version": {"type": "string"},
        "analyst_output_ids": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
