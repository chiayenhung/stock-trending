# Never commit real credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model identifiers are configuration, not code.
STOCKTREND_OPENAI_MODEL=gpt-5.6
STOCKTREND_ANTHROPIC_MODEL=claude-opus-4-8
STOCKTREND_CODEX_MODEL=
STOCKTREND_CLAUDE_CODE_MODEL=sonnet

# Completion artifacts always exclude credentials and raw provider prompts.
STOCKTREND_SUMMARY_EMAIL=hodalalala@gmail.com

# Approved live research source. Create a personal Tiingo account, accept its
# terms, and copy the data-only API token from https://api.tiingo.com/account/api/token
STOCKTREND_TIINGO_API_TOKEN=
STOCKTREND_SEC_USER_AGENT="Stock Trend Workflow/2.2 (contact@example.com)"

# Optional normalized gateway fallback. It remains disabled until its endpoint,
# licensing, retention, and read-only credential review is complete.
STOCKTREND_MARKET_DATA_URL=
STOCKTREND_MARKET_DATA_HOST=
STOCKTREND_MARKET_DATA_TOKEN=
